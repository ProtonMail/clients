<html data-protonmail-message="true"><head>
    <style>
    .main {
      color: #000 !important;
    }
    html {
      background-color: #fff !important;
    }
    @media (prefers-color-scheme: dark) {
      .main {
        color: #fff !important;
      }
      html {
        background-color: #000 !important;
      }
    }
    </style>
  <style type="text/css">/* <light_and_dark_css> */</style></head>
