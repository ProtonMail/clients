---
source: mail/mail-html-transformer/src/tests/dark_mode.rs
expression: html.to_string()
---
<html data-protonmail-message="true"><head>
    <style>span{background-color: rgb(151, 202, 133);}</style>
  <style type="text/css">/* <light_and_dark_css> */</style><style type="text/css">
                  @media ( prefers-color-scheme: dark ) {
                      [data-protonmail-message] span {
background-color: #3e6b2e !important
 }

[data-protonmail-message] font[color="black"] {
 color: #fff;
 }[data-protonmail-message] table[bgcolor="ffffff"] {
 background-color: #191927;
 }[data-protonmail-message] td[bgcolor="white"] {
 background-color: #191927;
 }
                  }
                </style></head>
  <body>
    <table>
        <tbody><tr><td bgcolor="white">
            <font color="black">
                Hello world!
            </font>
        </td>
        <!-- Repeat tags multiple times with the same style  -->
         <td bgcolor="white">1</td>
         <td bgcolor="white">2</td>
         <td bgcolor="white">3</td>
    </tr></tbody></table>
   <!-- A case where the hex color representation lacks `#` prefix but the browser still understands it -->
    <table bgcolor="ffffff"><tbody><tr><td>4</td></tr></tbody></table>
  

</body></html>
