load("@crate_index//:defs.bzl", "all_crate_deps")
load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test", "rust_test_suite")

_MAIL_COMMON_DEPS = [
    "//project/core/rust/core-event-loop",
    "//project/mail/rust/account/account-api:mail-account-api",
    "//project/mail/rust/api/mail-api-labels",
    "//project/mail/rust/calendar/calendar-api:mail-calendar-api-v1",
    "//project/mail/rust/calendar/calendar-common:mail-calendar-common",
    "//project/mail/rust/contacts/contacts-common:mail-contacts-common",
    "//project/mail/rust/core/core-api:mail-core-api",
    "//project/mail/rust/core/core-common:mail-core-common",
    "//project/mail/rust/crypto/crypto-inbox:mail-crypto-inbox",
    "//project/mail/rust/mail/mail-api:mail-api",
    "//project/mail/rust/mail/mail-html-transformer",
    "//project/mail/rust/mail/mail-search",
    "//project/mail/rust/shared/action-queue:mail-action-queue",
    "//project/mail/rust/shared/canonical-email:mail-canonical-email",
    "//project/mail/rust/shared/issue-reporter-service:mail-issue-reporter-service",
    "//project/mail/rust/shared/log-service:mail-log-service",
    "//project/mail/rust/shared/mail-local-id",
    "//project/mail/rust/shared/mail-package-builder:mail-package-builder",
    "//project/mail/rust/shared/event-service:mail-event-service",
    "//project/mail/rust/shared/mailto:mail-mailto",
    "//project/mail/rust/shared/network-monitor-service:mail-network-monitor-service",
    "//project/mail/rust/shared/observability:mail-observability",
    "//project/mail/rust/shared/sqlite3:mail-sqlite3",
    "//project/mail/rust/shared/stash:mail-stash",
    "//project/mail/rust/shared/task-service:mail-task-service",
    "//project/mail/rust/shared/telemetry-service:mail-telemetry",
]

rust_library(
    name = "mail-common",
    srcs = glob(["src/**/*.rs"]),
    compile_data = ["Cargo.toml"] + glob(["src/db/offline_migrations/**"]),
    crate_features = [
        "events-v6",
        "foundation_search",
        "sql",
    ],
    edition = "2024",
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
    ) + [
        "//project/mail/rust/mail/mail-common-derive:mail-common-derive",
    ],
    visibility = ["//visibility:public"],
    deps = all_crate_deps(
        normal = True,
    ) + _MAIL_COMMON_DEPS,
)

_MAIL_COMMON_INTEGRATION_DEPS = [
    dep.replace(
        "//project/mail/rust/core/core-api:mail-core-api",
        "//project/mail/rust/core/core-api:mail-core-api-with-mocks",
    ).replace(
        "//project/mail/rust/core/core-common:mail-core-common",
        "//project/mail/rust/core/core-common:mail-core-common-with-test-utils",
    ).replace(
        "//project/mail/rust/mail/mail-api:mail-api",
        "//project/mail/rust/mail/mail-api:mail-api-with-mocks",
    ).replace(
        "//project/mail/rust/mail/mail-search",
        "//project/mail/rust/mail/mail-search:mail-search-with-mocks",
    ).replace(
        "//project/mail/rust/shared/mail-package-builder:mail-package-builder",
        "//project/mail/rust/shared/mail-package-builder:mail-package-builder-with-mocks",
    ).replace(
        "//project/mail/rust/api/mail-api-labels",
        "//project/mail/rust/api/mail-api-labels:mail-api-labels-with-mocks",
    )
    for dep in _MAIL_COMMON_DEPS
]

_MAIL_COMMON_TEST_WORKSPACE_DEPS = [
    "//project/mail/rust/contacts/contacts-common:mail-contacts-common-with-test-utils",
    "//project/mail/rust/crypto/crypto-calendar:mail-crypto-calendar-with-test-utils",
]

_MAIL_COMMON_OVERRIDE_LABELS = [
    "//project/mail/rust/api/mail-api-labels",
    "//project/mail/rust/calendar/calendar-api:mail-calendar-api-v1",
    "//project/mail/rust/contacts/contacts-common:mail-contacts-common",
    "//project/mail/rust/core/core-api:mail-core-api",
    "//project/mail/rust/core/core-common:mail-core-common",
    "//project/mail/rust/crypto/crypto-calendar:mail-crypto-calendar",
    "//project/mail/rust/mail/mail-api:mail-api",
]

_MAIL_COMMON_THIRD_PARTY_DEPS = [
    dep
    for dep in all_crate_deps(
        normal = True,
    )
    if str(dep) not in _MAIL_COMMON_OVERRIDE_LABELS
]

rust_library(
    name = "mail-common-with-test-utils",
    testonly = True,
    srcs = glob(["src/**/*.rs"]),
    compile_data = ["Cargo.toml"] + glob(["src/db/offline_migrations/**"]),
    crate_features = [
        "events-v6",
        "foundation_search",
        "sql",
        "test-utils",
    ],
    crate_name = "mail_common",
    edition = "2024",
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
    ) + [
        "//project/mail/rust/mail/mail-common-derive:mail-common-derive",
    ],
    visibility = ["//project/mail/rust:__subpackages__"],
    deps = _MAIL_COMMON_THIRD_PARTY_DEPS + _MAIL_COMMON_INTEGRATION_DEPS + [
        "//project/mail/rust/contacts/contacts-api:mail-contacts-api-with-mocks",
    ],
)

rust_test(
    name = "mail-common-test",
    size = "small",
    crate = ":mail-common",
    crate_features = ["test-utils"],
    data = glob(["src/**/*.snap"]),
    edition = "2024",
    env = {"INSTA_WORKSPACE_ROOT": "."},
    proc_macro_deps = all_crate_deps(
        proc_macro_dev = True,
    ),
    tags = ["manual"],
    deps = all_crate_deps(
        normal_dev = True,
    ),
)

_MAIL_COMMON_INTEGRATION_TEST_CRATE_DEPS = [
    dep
    for dep in all_crate_deps(
        normal = True,
        normal_dev = True,
    )
    if str(dep) not in _MAIL_COMMON_OVERRIDE_LABELS
]

rust_test_suite(
    name = "mail-common-integration-tests",
    size = "medium",
    srcs = glob(
        ["tests/*.rs"],
        exclude = [
            "tests/drafts_common.rs",
            "tests/rsvp.rs",
        ],
    ),
    compile_data = glob(
        ["tests/**/*.rs"],
        exclude = glob(["tests/*.rs"]),
    ) + glob(["tests/**/*.json"]),
    data = glob([
        "tests/**/*.snap",
        "tests/**/fixtures/**",
    ]),
    env = {"INSTA_WORKSPACE_ROOT": "."},
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ) + [
        "//project/mail/rust/mail/mail-common-derive:mail-common-derive",
    ],
    shared_srcs = ["tests/drafts_common.rs"],
    deps = _MAIL_COMMON_INTEGRATION_TEST_CRATE_DEPS + [
        ":mail-common-with-test-utils",
        "//project/mail/rust/contacts/contacts-api:mail-contacts-api-with-mocks",
        "@crate_index//:wiremock",
    ] + _MAIL_COMMON_INTEGRATION_DEPS + _MAIL_COMMON_TEST_WORKSPACE_DEPS,
)
