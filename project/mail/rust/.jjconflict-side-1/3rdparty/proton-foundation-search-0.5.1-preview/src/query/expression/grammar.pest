// Pest grammar for search query expressions
// Based on the BNF grammar in nom-parser-bnf-grammar.md
//
// DESIGN NOTE: This grammar treats ALL values as strings (no typed literals)
// - "true" → STRING (not BOOLEAN)
// - "123"  → STRING (not INTEGER)
// - Everything is text, type interpretation is hidden in Rust layer
// See comments near `value` rule for restoration instructions
//
// Using built-in rules - see https://pest.rs/book/grammars/built-ins.html

WS = _{ " " | "\t" | "\r" | "\n" }

query = { SOI ~ WS* ~ expression? ~ WS* ~ EOI }

expression = { or_seq }

or_seq = { and_seq ~ (WS* ~ or_op ~ WS* ~ and_seq)* ~ WS* }

or_op = { "OR" | "or" }

and_seq = { primary_expr ~ ( (WS* ~ and_op ~ WS* ~ primary_expr) | (WS+ ~ !or_op ~ !and_op ~ primary_expr) )* }

and_op = { "AND" | "and" }

primary_expr = { not_expr | group_expr | term_expr }

not_expr = { "!" ~ primary_expr }

group_expr = { "(" ~ expression ~ ")" }

term_expr = { field_term | operator_term | simple_term }

field_term = { FIELD ~ OPERATOR ~ value }

operator_term = { OPERATOR ~ value }

simple_term = { value }

// NOTE: Current design treats everything as STRING (no type distinctions)
// This means "true", "false", "123" are all parsed as text strings.
//
// TO RESTORE BOOLEAN/NUMBER SUPPORT:
// 1. Change: value = { BOOLEAN | INTEGER | STRING }
// 2. Add negative lookahead to BOOLEAN to prevent "truethy" matching as "true":
//    BOOLEAN = @{ ("true" | "false" | "TRUE" | "FALSE") ~ !ALPHANUM }
// 3. Add negative lookahead to INTEGER to prevent "64bit" matching as "64":
//    INTEGER = @{ DIGIT+ ~ !LETTER }
// 4. Update pest_parser.rs to add Rule::BOOLEAN and Rule::INTEGER cases to to_value() match
//
// WHY NEGATIVE LOOKAHEAD: Without it, "truethy" would parse as BOOLEAN("true") + error("thy")
// TRADE-OFF: Simpler grammar vs typed literals
value = { STRING }

STRING = { QUOTED_STRING | UNQUOTED_STRING }

// Lexical rules

// TODO: support quoted/unquoted attribute names
FIELD = @{ (ASCII_DIGIT | ASCII_ALPHA)+ }

// Operators (order matters for multi-char operators like <= and >=)
OPERATOR = @{
    "<=" |  // Less than or equal (must come before <)
    ">=" |  // Greater than or equal (must come before >)
    "~"  |  // Matches (fuzzy search)
    "="  |  // Equals (exact match)
    "<"  |  // Less than
    ">"     // Greater than
}

QUOTED_STRING = {
    PUSH( "'" | "\"" ) ~
    (QSTRING | WILDCARD | ESCAPED_CHAR)+ ~
    POP
}
QSTRING = { (!(PEEK | ESCAPE | WILDCARD) ~ ANY)+ }

// Alphanumeric string - can start with letter or digit
// Must contain at least one non-digit character to distinguish from NUMBER
UNQUOTED_STRING = {
     (USTRING | WILDCARD | ESCAPED_CHAR)+
}
// This covers all unicode letters and numbers, not just ascii
USTRING = { (LETTER | NUMBER)+ }

ESCAPED_CHAR = { ESCAPE ~ ANY }
ESCAPE = _{ "\\" }

WILDCARD = { "*" }
