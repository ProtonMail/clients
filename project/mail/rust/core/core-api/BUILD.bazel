    visibility = ["//visibility:public"],
    deps = all_crate_deps(
        normal = True,
    ) + [
        "//project/mail/rust/account/account-api:mail-account-api",
        "//project/mail/rust/account/account-ids:mail-account-ids",
        "//project/mail/rust/api/mail-api-bug-report",
        "//project/mail/rust/api/mail-api-device",
        "//project/mail/rust/api/mail-api-event-types",
        "//project/mail/rust/api/mail-api-feature-flags",
        "//project/mail/rust/api/mail-api-labels",
        "//project/mail/rust/api/mail-api-ping",
        "//project/mail/rust/api/mail-api-session",
        "//project/mail/rust/api/mail-api-shared",
        "//project/mail/rust/contacts/contacts-api:mail-contacts-api",
        "//project/mail/rust/shared/api-utils:mail-api-utils",
        "//project/mail/rust/shared/mail-proton-ids",
        "//project/mail/rust/shared/network-monitor-service:mail-network-monitor-service",
        "//project/mail/rust/shared/stash:mail-stash",
        "//project/mail/rust/shared/task-service:mail-task-service",
        "@crate_index//:mail-muon",
