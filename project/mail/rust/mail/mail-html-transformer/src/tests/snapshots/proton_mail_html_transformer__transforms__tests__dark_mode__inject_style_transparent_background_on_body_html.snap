---
source: mail/mail-html-transformer/src/tests/dark_mode.rs
expression: html.to_string()
---
<html data-protonmail-message="true"><head>
        <style>
            html {
                background-color: #0000;
            }
            body {
                background-color: rgba(0, 0, 0, 0);
            }
            .transparent-div {
                background-color: transparent;
            }
        </style>
    <style type="text/css">/* <light_and_dark_css> */</style><style type="text/css">
                  @media ( prefers-color-scheme: dark ) {
                      [data-protonmail-message] body {
background-color: #191927 !important
 }html[data-protonmail-message] {
background-color: #191927 !important
 }
[data-protonmail-message] body[style*="background-color: #0000"] {
 background-color: #191927 !important
 }

                  }
                </style></head>
    <body style="background-color: #0000" data-proton-original-style="background-color: #0000 !important">
        <div style="background-color: #0000 !important">
            This div should stay transparent
        </div>
        <div class="transparent-div">
            This div with class should also stay transparent
        </div>
        <p>Some text content</p>
    

</body></html>
