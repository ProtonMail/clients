#!/bin/bash

try_cargo() {
    cargo $@
    test $? -eq 0 || exit 1
}

echo "Running rustfmt..."
try_cargo fmt --check --all

echo "Running clippy..."
try_cargo clippy --workspace --all-features --all-targets -- -D warnings

echo "Building project..."
try_cargo build --workspace --all-features --all-targets

echo "Generating documentation..."
try_cargo doc --workspace --all-features --no-deps

echo "Running tests..."
try_cargo test -F muon/test-local
