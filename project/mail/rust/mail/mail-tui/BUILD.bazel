load("@crate_index//:defs.bzl", "all_crate_deps")
load("@rules_rust//rust:defs.bzl", "rust_binary")

rust_binary(
    name = "mail-tui",
    srcs = glob(["src/**/*.rs"]),
    edition = "2024",
    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = all_crate_deps(
        normal = True,
    ) + [
        "//project/mail/rust/account/account-api:mail-account-api",
        "//project/mail/rust/calendar/calendar-api:mail-calendar-api-v1",
        "//project/mail/rust/calendar/calendar-common:mail-calendar-common",
        "//project/mail/rust/core/core-common:mail-core-common",
        "//project/mail/rust/crypto/crypto-inbox:mail-crypto-inbox",
        "//project/mail/rust/mail/mail-api",
        "//project/mail/rust/mail/mail-common",
        "//project/mail/rust/mail/mail-historic-ephemeral-load",
        "//project/mail/rust/mail/mail-html-transformer",
        "//project/mail/rust/shared/action-queue:mail-action-queue",
        "//project/mail/rust/shared/issue-reporter-service:mail-issue-reporter-service",
        "//project/mail/rust/shared/log-service:mail-log-service",
        "//project/mail/rust/shared/network-monitor-service:mail-network-monitor-service",
        "//project/mail/rust/shared/stash:mail-stash",
    ],
)
