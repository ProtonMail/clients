---
source: mail/mail-html-transformer/src/tests/dark_mode.rs
expression: html.to_string()
---
<html data-protonmail-message="true"><head>
    <style>span{background-color: rgb(151, 202, 133);}</style>
  <style type="text/css">/* <light_and_dark_css> */</style><style type="text/css">
                  @media ( prefers-color-scheme: dark ) {
                      [data-protonmail-message] span {
background-color: #3e6b2e !important
 }
[data-protonmail-message] div[class="a"][style*="background-color: #fff"] {
 background-color: #191927 !important
 }[data-protonmail-message] div[class="a"][style*="color: #000"] {
 color: #fff !important
 }[data-protonmail-message] div[class="b"][style*="color: #000"] {
 color: #fff !important
 }

                  }
                </style></head>
  <body>
    <div class="a" style="background-color: #fff" data-proton-original-style="background-color: hsl(0, 0%, 100%);"></div>
    <div style="font-family:&quot;Google Sans&quot;,Arial,sans-serif;font-weight:400 color: red"></div>
    <div class="a" style="color: #000" data-proton-original-style="color: black;">a</div>
    <div class="b" style="color: #000" data-proton-original-style="color: black !important">b</div>
    <span>abc</span>

    <!-- Repeat tags multiple times with the same style  -->
     
    <div class="b" style="color: #000" data-proton-original-style="color: black !important">b</div>
    <div class="b" style="color: #000" data-proton-original-style="color: black !important">b</div>
    <div class="b" style="color: #000" data-proton-original-style="color: black !important">b</div>
    
  

</body></html>
